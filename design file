module counter_4bit (
    input  wire clk,
    input  wire rst,
    input  wire en,
    input  wire up,
    output reg [3:0] count
);

    always @(posedge clk) begin
        if (rst)
            count <= 4'b0000;
        else if (en && up)
            count <= count + 1;
        else if (en && ~up)
            count <= count - 1;
    end
endmodule
